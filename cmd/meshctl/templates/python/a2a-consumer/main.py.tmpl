#!/usr/bin/env python3
"""
{{ if .A2ACardName }}{{ .A2ACardName }} bridge{{ else }}A2A consumer bridge{{ end }} - generated by meshctl scaffold a2a-consumer.

{{ if .Description }}{{ .Description }}
{{ end }}
Bridges {{ .A2AURL }}'s skills as mesh capabilities so downstream
mesh agents can consume them through the standard mesh resolution
machinery (capability + tag failover applies the moment a second
consumer registers the same capability).

{{ if .Offline }}This is an OFFLINE placeholder skeleton. Fill in the producer URL
and skill IDs below before running.
{{ else }}Generated from: {{ .A2AURL }}/.well-known/agent.json
{{ end }}

Decorator order matters
=======================

@mesh.agent MUST be the LAST decorator in the file. Its auto_run=True
path triggers the mcp_startup pipeline INLINE (uvicorn boot, registry
handshake), which blocks the importing thread before any module-level
code below it can run.
"""

import json
import os

# Set MCP_MESH_HTTP_PORT BEFORE importing mesh so the framework's
# display_config picks up the port we'll bind to.
HTTP_PORT = int(os.environ.setdefault("MCP_MESH_HTTP_PORT", "{{ .Port }}"))

import mesh
from fastmcp import FastMCP

app = FastMCP("{{ toPascalCase .Name }} Bridge")

{{ range .Skills }}

@app.tool()
@mesh.a2a_consumer(
    capability="{{ .Capability }}",
    a2a_url="{{ $.A2AURL }}",
    a2a_skill_id="{{ .ID }}",
    tags={{ if .Tags }}{{ toJSON .Tags }}{{ else }}[]{{ end }},{{ if $.AuthBearer }}
    auth=mesh.A2ABearer(token_env="{{ $.AuthEnvVar }}"),{{ end }}
)
async def {{ .FunctionName }}(_a2a: mesh.A2AClient = None) -> dict:
    """{{ .Description }}"""
    response = await _a2a.send(
        message={"role": "user", "parts": [{"type": "text", "text": "TODO: build A2A message"}]},
    )
    # The producer's artifact text is JSON; recover the dict here.
    # If the producer returns plain text, return response.artifact_text directly.
    try:
        return json.loads(response.artifact_text)
    except (ValueError, TypeError):
        return {"text": response.artifact_text}

{{ end }}

# @mesh.agent MUST be last - see module docstring for why.
@mesh.agent(
    name="{{ .Name }}",
    version="1.0.0",{{ if .Description }}
    description="{{ .Description }}",{{ end }}
    http_port=HTTP_PORT,
)
class {{ toPascalCase .Name }}:
    """A2A consumer bridge agent."""

    pass
