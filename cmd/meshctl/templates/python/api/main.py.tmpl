#!/usr/bin/env python3
"""
{{ .Name }} - MCP Mesh API Gateway

{{ if .Description }}{{ .Description }}{{ else }}An HTTP API gateway that consumes mesh capabilities via @mesh.route.{{ end }}
"""

import mesh
from fastapi import FastAPI, HTTPException, Request
from mesh.types import McpMeshTool

app = FastAPI(
    title="{{ toPascalCase .Name }}",
    description="{{ if .Description }}{{ .Description }}{{ else }}MCP Mesh API gateway for {{ .Name }}{{ end }}",
    version="1.0.0",
)


# ===== HEALTH CHECK =====

@app.get("/health")
async def health():
    """Health check endpoint."""
    return {"status": "healthy", "service": "{{ .Name }}"}


# ===== API ENDPOINTS =====

@app.get("/api/hello")
@mesh.route(dependencies=["hello"])
async def hello_endpoint(request: Request, hello: McpMeshTool = None):
    """
    Example API endpoint that calls the "hello" mesh capability.

    The @mesh.route decorator declares dependencies on mesh capabilities.
    At request time, the framework resolves each dependency and injects
    it as a McpMeshTool parameter (matched by parameter name).
    """
    if not hello:
        raise HTTPException(status_code=503, detail="hello capability unavailable")
    result = await hello()
    return {"result": result}


