@app.get("/")
async def root():
    """Root endpoint listing available API routes."""
    return {
        "service": "{{ .Name }}",
        "endpoints": [
            "GET  /health     - Health check",
            "GET  /api/hello  - Call hello capability",
        ],
    }


if __name__ == "__main__":
    import uvicorn

    uvicorn.run(app, host="0.0.0.0", port={{ .Port }}, log_level="info")
