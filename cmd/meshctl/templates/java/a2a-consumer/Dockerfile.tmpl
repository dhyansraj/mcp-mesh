# Dockerfile for {{ .Name }} A2A consumer bridge (Java/Spring Boot)
FROM mcpmesh/java-runtime:1.4.1

WORKDIR /app

USER root

COPY pom.xml .
COPY src/ src/

RUN mvn package -DskipTests -q

RUN chown -R mcp-mesh:mcp-mesh /app

USER mcp-mesh

EXPOSE {{ .Port }}

# Base image has ENTRYPOINT ["java", "-jar"], so CMD only needs the jar path
CMD ["target/{{ .NameKebab }}-1.0.0-SNAPSHOT.jar"]
