package {{ .JavaPackage }};

import io.mcpmesh.MeshAgent;
import io.mcpmesh.MeshTool;
import io.mcpmesh.a2a.A2AClient;
import io.mcpmesh.a2a.A2AConsumer;
import io.mcpmesh.a2a.A2AResponse;
import org.springframework.boot.SpringApplication;
import org.springframework.boot.autoconfigure.SpringBootApplication;
import tools.jackson.databind.ObjectMapper;

import java.util.List;
import java.util.Map;

/**
 * {{ .NamePascal }} - A2A consumer bridge generated by meshctl scaffold a2a-consumer.
 *
 * <p>{{ if .Description }}{{ .Description }}{{ else }}Bridges an external A2A producer's skills onto the mesh.{{ end }}
 *
 * <p>Bridges {{ .A2AURL }}'s skills as mesh capabilities so downstream
 * mesh agents can consume them through the standard mesh resolution
 * machinery (capability + tag failover applies).
 *
{{ if .Offline }} * <p>This is an OFFLINE placeholder skeleton. Fill in the producer URL
 * and skill IDs below before running.
{{ else }} * <p>Generated from: {{ .A2AURL }}/.well-known/agent.json
{{ end }} */
@MeshAgent(
    name = {{ toJSON .Name }},
    version = "1.0.0",
    description = {{ if .Description }}{{ toJSON .Description }}{{ else }}"A2A consumer bridge"{{ end }},
    port = {{ .Port }}
)
@SpringBootApplication
public class {{ .NamePascal }}Application {

    private static final ObjectMapper JSON = new ObjectMapper();

    public static void main(String[] args) {
        SpringApplication.run({{ .NamePascal }}Application.class, args);
    }
{{ range .Skills }}
    @MeshTool(
        capability = {{ toJSON .Capability }},
        description = {{ toJSON .Description }},
        tags = { {{ range $i, $t := .Tags }}{{ if $i }}, {{ end }}{{ toJSON $t }}{{ end }} }
    )
    @A2AConsumer(
        url = {{ toJSON $.A2AURL }},
        skillId = {{ toJSON .ID }}{{ if $.AuthBearer }},
        authBearerEnv = {{ toJSON $.AuthEnvVar }}{{ end }}
    )
    public Map<String, Object> {{ .MethodName }}(A2AClient a2a) throws Exception {
        A2AResponse response = a2a.send(Map.of(
            "role", "user",
            "parts", List.of(Map.of("type", "text", "text", "TODO: build A2A message"))
        ));
        @SuppressWarnings("unchecked")
        Map<String, Object> payload = JSON.readValue(response.artifactText(), Map.class);
        return payload;
    }
{{ end }}
}
