# Dockerfile for {{ .Name }} A2A consumer bridge
FROM mcpmesh/typescript-runtime:2.2.1

WORKDIR /app

USER root

COPY package*.json ./
RUN npm ci --omit=dev

COPY . .
RUN chown -R mcp-mesh:mcp-mesh /app && chmod -R 755 /app

USER mcp-mesh

EXPOSE {{ .Port }}

# Base image has ENTRYPOINT ["npx", "tsx"], so CMD only needs the script path
CMD ["src/index.ts"]
