#!/usr/bin/env npx tsx
/**
 * {{ if .A2ACardName }}{{ .A2ACardName }} bridge{{ else }}A2A consumer bridge{{ end }} - generated by meshctl scaffold a2a-consumer.
 *
 * {{ if .Description }}{{ .Description }}{{ end }}
 *
 * Bridges {{ .A2AURL }}'s skills as mesh capabilities so downstream
 * mesh agents can consume them through the standard mesh resolution
 * machinery (capability + tag failover applies the moment a second
 * consumer registers the same capability).
 *
{{ if .Offline }} * This is an OFFLINE placeholder skeleton. Fill in the producer URL
 * and skill IDs below before running.
{{ else }} * Generated from: {{ .A2AURL }}/.well-known/agent.json
{{ end }} */
import { FastMCP, mesh, type A2AClient } from "@mcpmesh/sdk";
import { z } from "zod";

function parsePort(raw: string | undefined, fallback: number): number {
  const candidate = parseInt(raw ?? "", 10);
  if (!Number.isFinite(candidate) || candidate < 1 || candidate > 65535) {
    return fallback;
  }
  return candidate;
}

const HTTP_PORT = parsePort(process.env.MCP_MESH_HTTP_PORT, {{ .Port }});

const server = new FastMCP({
  name: "{{ toPascalCase .Name }} Bridge",
  version: "1.0.0",
});

const agent = mesh(server, {
  name: {{ toJSON .Name }},
  httpPort: HTTP_PORT,{{ if .Description }}
  description: {{ toJSON .Description }},{{ end }}
});

{{ range .Skills }}
agent.addTool({
  name: {{ toJSON .FunctionName }},
  capability: {{ toJSON .Capability }},
  tags: {{ if .Tags }}{{ toJSON .Tags }}{{ else }}[]{{ end }},
  description: {{ toJSON .Description }},
  parameters: z.object({}),
  a2aConfig: {
    url: {{ toJSON $.A2AURL }},
    skillId: {{ toJSON .ID }},{{ if $.AuthBearer }}
    authBearerEnv: {{ toJSON $.AuthEnvVar }},{{ end }}
  },
  execute: async (_args, ..._injected) => {
    // _injected[0] is the framework-injected A2AClient. If you later add
    // task=true to this tool, JobController will be appended at index 1.
    const a2a = _injected[0] as A2AClient | null;
    if (!a2a) {
      throw new Error("A2AClient was not injected - did you set a2aConfig?");
    }
    const r = await a2a.send({
      role: "user",
      parts: [{ type: "text", text: "TODO: build A2A message" }],
    });
    if (!r.artifactText) return "";
    try {
      return JSON.parse(r.artifactText);
    } catch {
      return r.artifactText;
    }
  },
});

{{ end }}

console.log(
  `{{ .Name }} A2A consumer bridge defined on port ${HTTP_PORT}. Waiting for auto-start...`,
);
