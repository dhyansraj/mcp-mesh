/**
 * {{ .Name }} - MCP Mesh API Gateway
 *
 * {{ if .Description }}{{ .Description }}{{ else }}An HTTP API gateway that consumes mesh capabilities via mesh.route().{{ end }}
 */

import express, { Request, Response } from "express";
import { mesh } from "@mcpmesh/sdk";

const app = express();
app.use(express.json());

const PORT = process.env.PORT || {{ .Port }};

// ===== HEALTH & INFO ENDPOINTS =====

app.get("/", (req: Request, res: Response) => {
  res.json({
    service: "{{ .Name }}",
    endpoints: [
      "GET  /health     - Health check",
      "GET  /api/hello  - Call hello capability",
    ],
  });
});

app.get("/health", (req: Request, res: Response) => {
  res.json({ status: "healthy", service: "{{ .Name }}" });
});

// ===== API ENDPOINTS =====

/**
 * GET /api/hello
 *
 * Example endpoint that calls the "hello" mesh capability.
 * The mesh.route() middleware resolves the dependency and injects
 * it into the handler via the deps object.
 */
app.get(
  "/api/hello",
  mesh.route([{ capability: "hello" }], async (req, res, { hello }) => {
    if (!hello) {
      return res.status(503).json({ error: "hello capability unavailable" });
    }

    try {
      const result = await hello({});
      res.json({ result });
    } catch (err) {
      console.error("Call failed:", err);
      res.status(500).json({ error: "Call failed" });
    }
  })
);

