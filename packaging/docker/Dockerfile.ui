# Stage 1: Build Next.js SPA
FROM node:22-alpine AS ui-builder
WORKDIR /src/ui
COPY src/ui/package.json src/ui/package-lock.json ./
RUN npm ci --silent
COPY src/ui/ ./
RUN npm run build

# Stage 2: Build Go binary
FROM golang:1.25-alpine AS go-builder
RUN apk add --no-cache git gcc musl-dev sqlite-dev build-base
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
# Copy SPA build output into embed directory
COPY --from=ui-builder /src/ui/out cmd/mcp-mesh-ui/out/
ENV CGO_ENABLED=1
ENV CGO_CFLAGS="-D_LARGEFILE64_SOURCE"
RUN cd cmd/mcp-mesh-ui && \
    go build -tags "sqlite_omit_load_extension" -ldflags="-s -w" -o mcp-mesh-ui .

# Stage 3: Runtime
FROM alpine:latest
RUN apk --no-cache add ca-certificates sqlite wget
RUN mkdir -p /data
RUN adduser -D -u 1000 appuser && chown -R appuser:appuser /data
COPY --from=go-builder /src/cmd/mcp-mesh-ui/mcp-mesh-ui /usr/local/bin/
USER appuser
WORKDIR /data
EXPOSE 3080
HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
    CMD wget --no-verbose --tries=1 --spider http://localhost:3080/api/ui-health || exit 1
CMD ["mcp-mesh-ui"]
